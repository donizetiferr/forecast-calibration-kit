{
  "name": "forecast-calibration-kit",
  "version": "0.1.2",
  "description": "Calibration metrics for probabilistic forecasts: Brier score, log loss, reliability diagram, Expected Calibration Error (ECE) and the Murphy decomposition of the Brier score. Zero runtime dependencies, strict TypeScript, with a CLI.",
  "keywords": [
    "brier-score",
    "calibration",
    "log-loss",
    "forecast-evaluation",
    "probabilistic-forecasting",
    "ece",
    "reliability-diagram",
    "murphy-decomposition",
    "scoring-rule",
    "statistics"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "forecast-calibration-kit": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "node dist/cli.js examples/sample.json",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "author": "Donizeti Ferreira",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donizetiferr/forecast-calibration-kit.git"
  },
  "homepage": "https://github.com/donizetiferr/forecast-calibration-kit#readme",
  "bugs": {
    "url": "https://github.com/donizetiferr/forecast-calibration-kit/issues"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^4.1.10"
  }
}
